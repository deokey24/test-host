{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SelfTerminateViaAsg",
      "Effect": "Allow",
      "Action": ["autoscaling:TerminateInstanceInAutoScalingGroup"],
      "Resource": "*",
      "Condition": {
        "StringEquals": { "autoscaling:ResourceTag/Project": "dockteacher-worker" }
      }
    },
    {
      "Sid": "ConsumeVideoJobQueue",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:ChangeMessageVisibility"
      ],
      "Resource": "arn:aws:sqs:ap-northeast-2:*:dockteacher-video-jobs"
    },
    {
      "Sid": "ReadWorkerSecrets",
      "Effect": "Allow",
      "Action": ["ssm:GetParameter", "ssm:GetParameters", "ssm:GetParametersByPath"],
      "Resource": "arn:aws:ssm:ap-northeast-2:*:parameter/dockteacher/worker*"
    }
  ]
}
