# 이 파일을 .env로 복사한 뒤 실제 값을 채워 넣는다. .env는 git에 커밋하지 않는다.

# 관리자 페이지
ADMIN_PASSWORD=dockAdmin
SESSION_SECRET=change-me

# MySQL (운영 서버에 설치)
DB_HOST=localhost
DB_USER=dockteacher_app
DB_PASSWORD=
DB_NAME=dockteacher

# Cloudflare R2 (S3 호환)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 기존 강의 CDN(img.wecandoeat.com)이 연결된 버킷 — raw/, final/ 프리픽스로 영상 파이프라인과 공유
R2_BUCKET=dockteacher
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# AWS (SQS, 워커 ASG 스케일아웃, SES)
AWS_REGION=ap-northeast-2
SQS_QUEUE_URL=
# 워커 Auto Scaling Group (기본값 있음 — 이름/최대 대수를 바꿀 때만 설정)
WORKER_ASG_NAME=dockteacher-worker-asg
WORKER_ASG_MAX=3

# SES (회원가입 확인 / 비밀번호 재설정 메일)
# SES에서 검증된 도메인/이메일이어야 함. 현재 검증된 신원: mail.dockteacher.co.kr 도메인
SES_FROM_EMAIL=no-reply@mail.dockteacher.co.kr
# 비밀번호 재설정 링크에 쓰이는 사이트 기본 URL
SITE_URL=https://dockteacher.co.kr
