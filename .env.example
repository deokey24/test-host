# 이 파일을 .env로 복사한 뒤 실제 값을 채워 넣는다. .env는 git에 커밋하지 않는다.

# 관리자 페이지
ADMIN_PASSWORD=dockAdmin
SESSION_SECRET=change-me

# MySQL (운영 서버에 설치)
DB_HOST=localhost
DB_USER=dockteacher_app
DB_PASSWORD=
DB_NAME=dockteacher

# Cloudflare R2 (S3 호환)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dockteacher-videos
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# AWS (SQS, EC2 start/stop)
AWS_REGION=ap-northeast-2
SQS_QUEUE_URL=
# 운영 서버가 워커를 깨울 때 사용할 인스턴스 ID
WORKER_INSTANCE_ID=
