# 이 파일을 .env로 복사한 뒤 실제 값을 채워 넣는다. .env는 git에 커밋하지 않는다.

# 관리자 페이지
ADMIN_PASSWORD=dockAdmin
SESSION_SECRET=change-me

# MySQL (운영 서버에 설치)
DB_HOST=localhost
DB_USER=dockteacher_app
DB_PASSWORD=
DB_NAME=dockteacher

# Cloudflare R2 (S3 호환)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dockteacher-videos
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# AWS (SQS, EC2 start/stop, SES)
AWS_REGION=ap-northeast-2
SQS_QUEUE_URL=
# 운영 서버가 워커를 깨울 때 사용할 인스턴스 ID
WORKER_INSTANCE_ID=

# SES (회원가입 확인 / 비밀번호 재설정 메일)
# SES에서 검증된 도메인/이메일이어야 함. 현재 검증된 신원: mail.dockteacher.co.kr 도메인
SES_FROM_EMAIL=no-reply@mail.dockteacher.co.kr
# 비밀번호 재설정 링크에 쓰이는 사이트 기본 URL
SITE_URL=https://dockteacher.co.kr
