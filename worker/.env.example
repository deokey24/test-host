# 워커 인스턴스의 .env — git에 커밋하지 않는다

# MySQL (운영 서버 54.116.171.96, 워커의 사설 IP를 DB 계정에 등록해야 접속 가능)
DB_HOST=<운영서버_사설IP_또는_퍼블릭IP>
DB_USER=dockteacher_worker
DB_PASSWORD=
DB_NAME=dockteacher

# Cloudflare R2 (S3 호환) — production과 동일 버킷, 별도 발급된 워커 전용 자격증명 권장
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dockteacher-videos
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# AWS
AWS_REGION=ap-northeast-2
SQS_QUEUE_URL=

# 워커 동작 옵션
WORKER_CONCURRENCY=5
WORKER_TMP_DIR=/mnt/worker-tmp
IDLE_TIMEOUT_MINUTES=10
FFMPEG_PRESET=medium
FFMPEG_CRF=23
